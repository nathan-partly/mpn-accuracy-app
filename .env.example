# ─── Database ──────────────────────────────────────────────────────────────────
# Neon (neon.tech), Vercel Postgres, or any Postgres-compatible connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Request from #eng-platform on Slack. Provide:
#   - App name: "MPN Accuracy Benchmarking"
#   - Redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# Must match your deployment URL exactly
NEXTAUTH_URL="https://mpn-accuracy.your-domain.com"
